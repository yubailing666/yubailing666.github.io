&lt;tr&gt;
&lt;td style="text-align: left"&gt;&lt;code&gt;GridLayout&lt;/code&gt;&lt;/td&gt;
&lt;td style="text-align: left"&gt;棋盘、等大方块&lt;/td&gt;
&lt;/tr&gt;
&lt;tr&gt;
&lt;td style="text-align: left"&gt;&lt;code&gt;BoxLayout&lt;/code&gt;&lt;/td&gt;
